# Copy this to /srv/mine-rescue/.env on the server and fill in real values.
# This file is read by the gunicorn systemd unit (EnvironmentFile).
#
# Generate a fresh secret key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

DJANGO_SECRET_KEY=replace-with-a-freshly-generated-50-character-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
